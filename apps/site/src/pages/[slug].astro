---
import Layout from '../../layouts/Base.astro';
import { db, pages } from '../../lib/db';
import { eq, and, sql } from 'drizzle-orm';

const { slug } = Astro.params;

// Fetch the page
const [page] = await db
  .select()
  .from(pages)
  .where(and(eq(pages.slug, slug!), eq(pages.status, 'published'), sql`${pages.deletedAt} IS NULL`))
  .limit(1);

if (!page) {
  return Astro.redirect('/404');
}
---

<Layout title={page.title}>
  <article class="prose prose-lg dark:prose-invert max-w-none">
    <h1 class="text-4xl font-bold mb-8">{page.title}</h1>

    <div>
      {page.content && typeof page.content === 'object' && 'html' in page.content ? (
        <div set:html={(page.content as any).html} />
      ) : (
        <pre class="whitespace-pre-wrap">{JSON.stringify(page.content, null, 2)}</pre>
      )}
    </div>
  </article>
</Layout>
