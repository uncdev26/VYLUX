---
import Layout from '../../layouts/Base.astro';
import { db, posts, categories } from '../../lib/db';
import { eq, and, sql } from 'drizzle-orm';

const { slug } = Astro.params;

// Fetch the post
const [post] = await db
  .select()
  .from(posts)
  .where(and(eq(posts.slug, slug!), eq(posts.status, 'published'), sql`${posts.deletedAt} IS NULL`))
  .limit(1);

if (!post) {
  return Astro.redirect('/404');
}

// Fetch category if exists
let category = null;
if (post.categoryId) {
  [category] = await db
    .select()
    .from(categories)
    .where(eq(categories.id, post.categoryId))
    .limit(1);
}
---

<Layout title={post.title} description={post.excerpt || ''}>
  <article class="prose prose-lg dark:prose-invert max-w-none">
    <header class="mb-8">
      <h1 class="text-4xl font-bold mb-4">{post.title}</h1>
      <div class="flex items-center gap-4 text-gray-500 text-sm">
        {post.publishedAt && (
          <time>
            {new Date(post.publishedAt).toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </time>
        )}
        {category && (
          <span class="px-2 py-1 bg-gray-100 dark:bg-gray-800 rounded text-xs">
            {category.name}
          </span>
        )}
      </div>
    </header>

    <div class="mt-8">
      {post.content && typeof post.content === 'object' && 'html' in post.content ? (
        <div set:html={(post.content as any).html} />
      ) : (
        <pre class="whitespace-pre-wrap">{JSON.stringify(post.content, null, 2)}</pre>
      )}
    </div>
  </article>
</Layout>
