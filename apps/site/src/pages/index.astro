---
import Layout from '../layouts/Base.astro';
import { db, posts, categories } from '../lib/db';
import { eq, and, desc, sql } from 'drizzle-orm';

// Fetch published posts
const recentPosts = await db
  .select({
    id: posts.id,
    title: posts.title,
    slug: posts.slug,
    excerpt: posts.excerpt,
    publishedAt: posts.publishedAt,
  })
  .from(posts)
  .where(and(eq(posts.status, 'published'), sql`${posts.deletedAt} IS NULL`))
  .orderBy(desc(posts.publishedAt))
  .limit(10);

// Fetch categories
const allCategories = await db
  .select()
  .from(categories)
  .where(sql`${categories.deletedAt} IS NULL`);

// Structured data
const siteUrl = Astro.site?.toString() || 'http://localhost:4321';
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'VYLUX',
  url: siteUrl,
  description: 'AI-powered content management. Chat to create.',
};
---

<Layout title="VYLUX — Home" structuredData={structuredData}>
  <section class="mb-12">
    <h1 class="text-4xl font-bold mb-4">Welcome to VYLUX</h1>
    <p class="text-lg text-gray-600 dark:text-gray-400">
      AI-powered content management. Chat to create.
    </p>
  </section>

  {recentPosts.length > 0 && (
    <section class="mb-12">
      <h2 class="text-2xl font-semibold mb-6">Latest Posts</h2>
      <div class="grid gap-6">
        {recentPosts.map((post) => (
          <article class="border border-gray-200 dark:border-gray-800 rounded-lg p-6 hover:shadow-md transition-shadow">
            <a href={`/blog/${post.slug}`}>
              <h3 class="text-xl font-semibold mb-2 hover:text-blue-600 dark:hover:text-blue-400">
                {post.title}
              </h3>
            </a>
            {post.excerpt && (
              <p class="text-gray-600 dark:text-gray-400 mb-3">{post.excerpt}</p>
            )}
            {post.publishedAt && (
              <time class="text-sm text-gray-500">
                {new Date(post.publishedAt).toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </time>
            )}
          </article>
        ))}
      </div>
    </section>
  )}

  {recentPosts.length === 0 && (
    <section class="text-center py-12">
      <p class="text-gray-500">No posts yet. Create your first post via chat!</p>
    </section>
  )}

  {allCategories.length > 0 && (
    <section>
      <h2 class="text-2xl font-semibold mb-4">Categories</h2>
      <div class="flex flex-wrap gap-2">
        {allCategories.map((cat) => (
          <span class="px-3 py-1 bg-gray-100 dark:bg-gray-800 rounded-full text-sm">
            {cat.name}
          </span>
        ))}
      </div>
    </section>
  )}
</Layout>
