---
import ChatWidget from '../components/ChatWidget.svelte';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'VYLUX - AI-Powered CMS' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <slot name="head" />
  </head>
  <body class="min-h-screen bg-white text-gray-900 dark:bg-gray-950 dark:text-gray-100">
    <header class="border-b border-gray-200 dark:border-gray-800">
      <div class="mx-auto max-w-5xl px-4 py-4">
        <a href="/" class="text-xl font-bold">VYLUX</a>
      </div>
    </header>

    <main class="mx-auto max-w-5xl px-4 py-8">
      <slot />
    </main>

    <footer class="border-t border-gray-200 dark:border-gray-800">
      <div class="mx-auto max-w-5xl px-4 py-4 text-sm text-gray-500">
        &copy; {new Date().getFullYear()} VYLUX. Powered by AI.
      </div>
    </footer>

    <ChatWidget client:load />
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
  }
  a {
    color: inherit;
    text-decoration: none;
  }
</style>
